# Server
PORT=3100
NODE_ENV=development

# Shared: OpenRouter (AI) — used by all orgs
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Dashboard — DASHBOARD_SECRET is REQUIRED in production (generate: openssl rand -hex 32)
DASHBOARD_PASSWORD=your_dashboard_password_here
DASHBOARD_SECRET=

# Webhook base URL (for Attio webhook registration)
# WEBHOOK_BASE_URL=https://custom-integration-hub.velocy.co

# --- Per-org credentials (prefix = envPrefix from organizations.json) ---

# WW Partners
WW_ATTIO_API_KEY=your_ww_attio_api_key
WW_ATTIO_WEBHOOK_SECRET=your_attio_webhook_signing_secret
WW_SLACK_BOT_TOKEN=xoxb-your-ww-slack-bot-token
WW_CLOUDTALK_API_ID=your_ww_cloudtalk_api_id
WW_CLOUDTALK_API_KEY=your_ww_cloudtalk_api_key
WW_BREVO_API_KEY=your_ww_brevo_api_key
WW_CALENDLY_API_TOKEN=your_ww_calendly_personal_access_token
WW_CALENDLY_WEBHOOK_SECRET=
WW_FATHOM_API_KEY=your_fathom_api_key
WW_FATHOM_WEBHOOK_SECRET=whsec_your_fathom_webhook_signing_secret
WW_NOTION_API_KEY=your_notion_internal_integration_api_key

# Velocy
VELOCY_ATTIO_API_KEY=your_velocy_attio_api_key
VELOCY_ATTIO_WEBHOOK_SECRET=your_attio_webhook_signing_secret
VELOCY_SLACK_BOT_TOKEN=xoxb-your-velocy-slack-bot-token

# BookClinic
BOOKCLINIC_SLACK_BOT_TOKEN=xoxb-your-bookclinic-slack-bot-token
BOOKCLINIC_SLACK_SIGNING_SECRET=your_slack_signing_secret_here
BOOKCLINIC_GITHUB_TOKEN=github_pat_your_token_here
BOOKCLINIC_VERCEL_WEBHOOK_SECRET=your_vercel_webhook_secret

# JI Personal
JI_FATHOM_API_KEY=your_ji_fathom_api_key
JI_FATHOM_WEBHOOK_SECRET=whsec_your_ji_fathom_webhook_signing_secret
JI_NOTION_API_KEY=your_ji_notion_api_key

# --- Monitoring (shared, cross-org) ---
MONITORING_SLACK_CHANNEL_ID=
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
